    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#follows"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#precedes"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
