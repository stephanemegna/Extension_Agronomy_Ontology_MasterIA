    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cacao -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cacao">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Plantain"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cacao_Variety -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cacao_Variety">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isVarietyOf"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cacao"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava_Variety"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize_Variety"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Plantain_Variety"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Plantain"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava_Variety -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava_Variety">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isVarietyOf"/>
                <owl:allValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Cassava"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Maize_Variety"/>
        <owl:disjointWith rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Plantain_Variety"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasVariety"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#FloweringStage -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#FloweringStage">
