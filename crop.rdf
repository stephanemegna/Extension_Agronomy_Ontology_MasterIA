    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#adaptedToClimate -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#adaptedToClimate">
