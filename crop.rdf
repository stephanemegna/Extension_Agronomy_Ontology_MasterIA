        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#concernsNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#concernsNutrient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Nutrient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#dependsOnClimate -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#dependsOnClimate">
