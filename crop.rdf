        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#TemperatureRequirement"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasVariety -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasVariety">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isVarietyOf"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isRequiredAtStage -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isRequiredAtStage">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Nutrient"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isVarietyOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#isVarietyOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#precedes -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#precedes">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


