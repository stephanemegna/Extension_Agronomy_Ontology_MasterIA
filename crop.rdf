        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasGrowthStage -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasGrowthStage">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasNutrientRequirement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasNutrientRequirement">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasTemperatureRequirement -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#hasTemperatureRequirement">
