<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation/"
     xml:base="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:Soil="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#"
     xmlns:crop="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
     xmlns:swrl="http://www.w3.org/2003/11/swrl#"
     xmlns:swrla="http://swrl.stanford.edu/ontologies/3.3/swrla.owl#"
     xmlns:climate="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#"
     xmlns:practice="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#"
     xmlns:situation="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation">
        <owl:versionIRI rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation/1.0"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop"/>
        <owl:imports rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice"/>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#concernsNutrient -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#concernsNutrient">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#NutrientLevel"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Nutrient"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#adaptedToSoil -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#adaptedToSoil">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#dependsOnSoil -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#dependsOnSoil">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#SoilProperty"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToCrop -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToCrop">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToSoil -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToSoil">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToVariety -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliedToVariety">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToCrop -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToCrop">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToGrowthStage -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToGrowthStage">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSituation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSituation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSituationType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSituationType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SituationType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSoil -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#appliesToSoil">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasClimate -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasClimate">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#Climate"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasCrop -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasCrop">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Crop"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasPractice -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasPractice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituation -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituation">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituationType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituationType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SituationType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSoil -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSoil">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#isSoilOf"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSoilType -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSoilType">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SoilType"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasTiming -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasTiming">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#GrowthStage"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasVariety -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasVariety">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#isSoilOf -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#isSoilOf">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#recommendedFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#recommendedFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#requiresPractice -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#requiresPractice">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasConfidenceLevel -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasConfidenceLevel">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasExpectedImpact -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasExpectedImpact">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasPriority -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasPriority">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasRecommendationText -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasRecommendationText">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#Climate -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#Climate">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#hasTemperature"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#Temperature"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NitrogenLevel -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NitrogenLevel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#NutrientLevel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#NutrientRequirement">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#dependsOnSoil"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#PhosphorusLevel -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#PhosphorusLevel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#NutrientLevel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#PotassiumLevel -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#PotassiumLevel">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#NutrientLevel"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#Variety">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/crop#adaptedToSoil"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/Soil#Soil"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasClimate"/>
                <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/climate#Climate"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CocoaWaterNutrientStress -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CocoaWaterNutrientStress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SituationType"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CombinedAgroStress -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CombinedAgroStress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SituationType"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CombinedWaterStress -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CombinedWaterStress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#StressSituation"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#ConditionTemperature -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#ConditionTemperature"/>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#DiseaseRiskSituation -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#DiseaseRiskSituation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#SituationType"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#DroughtStress -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#DroughtStress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#StressSituation"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#ExcessWaterSituation -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#ExcessWaterSituation">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#StressSituation"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#HeatStress -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#HeatStress">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#StressSituation"/>
    </owl:Class>
    


