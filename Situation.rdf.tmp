    <!-- http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice -->

    <owl:Class rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#RecommendedPractice">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#PracticeRequirement"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasPractice"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#AgriculturalPractice"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituation"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#AgriculturalSituation"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasRecommendationText"/>
                <owl:someValuesFrom rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:comment>Entité représentant une pratique agricole recommandée dans une situation agronomique spécifique, incluant le contexte, l’action et une description textuelle.</rdfs:comment>
    </owl:Class>
    


