    <!-- ========== SWRL INFERENCE RULES FOR PRACTICE RECOMMENDATION ========== -->
    
    <!-- Rule: If a situation has DroughtStress type, it requires Irrigation -->
    <rdf:Description rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#Rule_DroughtStress_Irrigation">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Implication"/>
        <swrl:body rdf:parseType="Collection">
            <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituationType"/>
                        <swrl:argument1>
                            <swrl:Variable>
                                <swrl:varName>situation</swrl:varName>
                            </swrl:Variable>
                        </swrl:argument1>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#DroughtStress"/>
                    </rdf:Description></swrl:body>
        <swrl:head rdf:parseType="Collection">
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#requiresPractice"/>
                <swrl:argument1>
                    <swrl:Variable>
                        <swrl:varName>situation</swrl:varName>
                    </swrl:Variable>
                </swrl:argument1>
                <swrl:argument2 rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/practice#Irrigation"/>
            </rdf:Description>
        </swrl:head>
    </rdf:Description>

    <!-- Rule: If a situation has CombinedWaterStress type, it requires Irrigation and NitrogenFertilization -->
    <rdf:Description rdf:about="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#Rule_CombinedWaterStress_Irrigation">
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Implication"/>
        <swrl:body rdf:parseType="Collection">
            <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                        <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#hasSituationType"/>
                        <swrl:argument1>
                            <swrl:Variable>
                                <swrl:varName>situation</swrl:varName>
                            </swrl:Variable>
                        </swrl:argument1>
                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#CombinedWaterStress"/>
                    </rdf:Description></swrl:body>
        <swrl:head rdf:parseType="Collection">
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#IndividualPropertyAtom"/>
                <swrl:propertyPredicate rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#requiresPractice"/>
                <swrl:argument1>
                    <swrl:Variable>
