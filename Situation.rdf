        <rdfs:comment>Infère la nécessité de drainage pour le manioc en condition d&apos;excès d&apos;eau.</rdfs:comment>
        <rdfs:label>cassavaDrainage_ExcessWater</rdfs:label>
        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#Imp"/>
        <swrl:body>
            <rdf:Description>
                <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#AtomList"/>
                <rdf:first>
                    <rdf:Description>
                        <rdf:type rdf:resource="http://www.w3.org/2003/11/swrl#ClassAtom"/>
