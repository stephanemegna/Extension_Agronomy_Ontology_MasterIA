                                        <swrl:argument1 rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation/csit2"/>
                                        <swrl:argument2 rdf:resource="http://www.semanticweb.org/megnastephane/ontologies/2026/3/situation#ExcessWaterSituation"/>
                                    </rdf:Description>
